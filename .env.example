# COS 自动更新上传凭证（开发机用，切勿提交真实值）
# 复制本文件为 .env 并填入真实值；.env 已被 .gitignore 忽略。
# 获取方式见 docs/features/auto-update.md「1.4 创建 API 密钥」

COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxx
COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
COS_BUCKET=your-update-bucket
COS_REGION=ap-shanghai

# 产品更新源。开源版默认不配置；闭源产品构建需要时注入。
# DEEPINK_UPDATE_BASE_URL=https://your-update-bucket.cos.ap-shanghai.myqcloud.com

# 私有 DeepInk 产品服务入口。
# 开源版默认不配置；闭源产品构建或本地联调时由环境注入。
# DEEPINK_API_URL=https://your-private-service.example.com

# 旧 CCLink 账号导入服务入口，仅闭源产品/迁移联调需要。
# CCLINK_LEGACY_API_URL=https://your-legacy-chatcc-service.example.com/index
