# CCLink Studio local development environment
#
# Copy this file to .env only for local experiments. The open source shell must
# run without official production endpoints, account services, subscription
# services, artifact upload credentials, signing material, or notarization
# secrets.

# Optional local-only update feed used for manual updater experiments.
# Leave unset for normal OSS development.
# CCLINK_STUDIO_UPDATE_BASE_URL=http://127.0.0.1:8787/updates

# Optional local Agent/device tooling paths.
# ANDROID_HOME=/Users/you/Library/Android/sdk
# ANDROID_SDK_ROOT=/Users/you/Library/Android/sdk
# CCLINK_STUDIO_CLAUDE_PATH=/opt/homebrew/bin/claude
