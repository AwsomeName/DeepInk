{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./out",
    "types": ["node"],
    "baseUrl": "."
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/preload/**/*.ts"
  ]
}
