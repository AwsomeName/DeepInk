# ─── 依赖 ──────────────────────────────────────────
node_modules/

# ─── 构建产物 ──────────────────────────────────────
out/
dist/
release/
*.tsbuildinfo

# 云函数打包产物（由 cloud/build-zip.sh 生成，不入库）
cloud/*.zip

# ─── Electron 打包输出 ─────────────────────────────
*.dmg
*.app
*.exe
*.AppImage
*.snap
*.deb
*.blockmap

# ─── 缓存 / 测试覆盖率 ─────────────────────────────
.vite/
.eslintcache
.cache/
coverage/

# ─── 日志 ──────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── 环境变量 / 密钥 ───────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# ─── 编辑器 / IDE（.cursor/ 规则需共享，故不忽略）───
.claude/
.vscode/
.idea/
*.swp
*.swo

# ─── 操作系统 ──────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
