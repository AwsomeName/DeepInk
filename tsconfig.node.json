{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./out",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "core-agent": ["../coreAgent/dist/index.d.ts"],
      "core-agent/*": ["../coreAgent/dist/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/preload/**/*.ts"
  ]
}
